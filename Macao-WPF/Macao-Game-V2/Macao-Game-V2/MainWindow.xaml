<Window x:Class="Macao_Game_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Macao_Game_V2"
        Title="Macao Game" Height="650" Width="900" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Card Button Style using CardVisual inside a Button -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                x:Name="CardBorder">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="15" Color="White" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="40" CenterY="60"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Back Style for Draw Pile -->
        <Style x:Key="CardBackStyle" TargetType="Button" BasedOn="{StaticResource CardButtonStyle}">
            <Setter Property="Background" Value="#FF2B2B2B"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background will be set dynamically from code-behind -->
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Dark Mode Toggle Button -->
        <Button x:Name="DarkModeToggle" Width="60" Height="60" 
                HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="20,10,0,0" Background="Transparent" BorderThickness="0"
                Click="DarkModeToggle_Click" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse x:Name="ToggleCircle" Width="50" Height="50" 
                                Fill="#FF333333" Stroke="#FF666666" StrokeThickness="2"/>
                        <TextBlock x:Name="ToggleIcon" Text="☀️" FontSize="28" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleCircle" Property="Fill" Value="#FF444444"/>
                            <Setter TargetName="ToggleCircle" Property="Stroke" Value="#FF888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Top: AI info & Game Messages -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Center" Margin="10">
                <TextBlock x:Name="AiStatusText" Text="AI Cards: 5" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <ScrollViewer x:Name="AiHandDebugArea" Visibility="Collapsed" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" MaxHeight="60" Margin="0,5,0,0">
                    <WrapPanel x:Name="AiHandPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ScrollViewer>
                <TextBlock x:Name="GameMessageText" Text="Welcome to Macao!" FontSize="18" Foreground="#FFFFD700" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                <TextBlock x:Name="TurnText" Text="Your Turn" FontSize="16" Foreground="LightGreen" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
                <TextBlock x:Name="HumanWinsText" Text="Your Wins: 0" FontSize="16" FontWeight="Bold" Foreground="LightGreen" />
                <TextBlock x:Name="AiWinsText" Text="AI Wins: 0" FontSize="16" FontWeight="Bold" Foreground="Orange" />
            </StackPanel>
        </Grid>

        <!-- Middle: Deck and Discard Pile -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <StackPanel Margin="20">
                <TextBlock Text="Draw Pile" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Button x:Name="DrawPileButton" Style="{StaticResource CardButtonStyle}" Click="DrawPile_Click" Background="#FF2B2B2B">
                    <Button.Content>
                        <TextBlock Text="DRAW" Foreground="White" FontSize="18"/>
                    </Button.Content>
                </Button>
            </StackPanel>

            <StackPanel Margin="20">
                <TextBlock Text="Top Card" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border x:Name="DiscardPileBorder" Width="80" Height="120" Background="White" CornerRadius="10" BorderBrush="Black" BorderThickness="2">
                    <local:CardVisual x:Name="TopCardVisual" IsFaceDown="False"/>
                </Border>
            </StackPanel>

            <StackPanel Margin="20" VerticalAlignment="Center">
                <TextBlock x:Name="CardsToDrawText" Text="Penalty: 0" Foreground="#FFFF5555" FontSize="16" FontWeight="Bold" Visibility="Hidden"/>
            </StackPanel>
        </StackPanel>

        <!-- Bottom: Player Hand -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" Margin="20" VerticalAlignment="Bottom">
            <WrapPanel x:Name="PlayerHandPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
        </ScrollViewer>

        <!-- Suit Selection Overlay -->
        <Grid x:Name="SuitSelectionOverlay" Grid.RowSpan="3" Background="#AA000000" Visibility="Hidden">
            <Border Background="White" CornerRadius="15" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <StackPanel>
                    <TextBlock Text="Choose a Suit" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <UniformGrid Columns="2" Rows="2" Width="200" Height="200">
                        <Button Content="♠" FontSize="40" Foreground="Black" Margin="5" Click="Suit_Click"/>
                        <Button Content="♥" FontSize="40" Foreground="Red" Margin="5" Click="Suit_Click"/>
                        <Button Content="♦" FontSize="40" Foreground="Red" Margin="5" Click="Suit_Click"/>
                        <Button Content="♣" FontSize="40" Foreground="Black" Margin="5" Click="Suit_Click"/>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Game Over Overlay -->
        <Grid x:Name="GameOverOverlay" Grid.RowSpan="3" Background="#EE000000" Visibility="Hidden">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="GameOverText" Text="Game Over" FontSize="48" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="Play Again" FontSize="24" Padding="20,10" HorizontalAlignment="Center" Click="RestartGame_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
